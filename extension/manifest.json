{
  "manifest_version": 3,
  "name": "AI Water Footprint Tracker",
  "version": "1.0",
  "description": "Calculates and displays the water footprint of AI responses.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://claude.ai/*"
      ],
      "js": [
        "content.bundle.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ],
  "host_permissions": [
    "http://chatgpt.com/*",
    "https://chatgpt.com/*",
    "http://claude.ai/*",
    "https://claude.ai/*"
  ]
}